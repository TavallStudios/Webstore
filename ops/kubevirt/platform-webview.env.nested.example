# Use this profile when the platform runs on a guest node pool that is itself virtualized.
# On x86_64 guests without /dev/kvm, configure KubeVirt useEmulation=true with configure-kubevirt-node.sh.
PLATFORM_KUBEVIRT_INFRASTRUCTURE_PROFILE=NESTED_KUBEVIRT
PLATFORM_KUBEVIRT_DEDICATED_NODE_SELECTOR=platform.tavall/runtime-profile=dedicated-kubevirt
PLATFORM_KUBEVIRT_NESTED_NODE_SELECTOR=platform.tavall/runtime-profile=nested-kubevirt
